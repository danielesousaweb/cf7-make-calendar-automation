<svg width="680" height="300" viewBox="0 0 680 300" xmlns="http://www.w3.org/2000/svg" role="img">
  <title>Architecture diagram: CF7 to Make to Google Calendar automation flow</title>
  <desc>A user submits a WordPress Contact Form 7 form. A PHP snippet intercepts the submission and posts a JSON webhook to Make.com. Make then calls the Google Calendar API to add the submitter as an event attendee, which triggers Google Calendar to send a Google Meet invite email automatically. An alternative entry point allows one-click confirmation via a tracked email link.</desc>
  <defs>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#5F5E5A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arrow-amber" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#BA7517" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  </defs>

  <style>
    text { font-family: -apple-system, "Segoe UI", Roboto, Arial, sans-serif; }
    .th { font-size: 14px; font-weight: 600; }
    .ts { font-size: 12px; font-weight: 400; }
  </style>

  <!-- 1. CF7 form -->
  <rect x="20" y="40" width="130" height="56" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.75"/>
  <text class="th" x="85" y="60" text-anchor="middle" fill="#042C53">CF7 form</text>
  <text class="ts" x="85" y="78" text-anchor="middle" fill="#0C447C">WordPress site</text>

  <line x1="150" y1="68" x2="186" y2="68" stroke="#5F5E5A" stroke-width="1.25" marker-end="url(#arrow)"/>

  <!-- 2. PHP snippet -->
  <rect x="190" y="40" width="130" height="56" rx="8" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.75"/>
  <text class="th" x="255" y="60" text-anchor="middle" fill="#04342C">PHP snippet</text>
  <text class="ts" x="255" y="78" text-anchor="middle" fill="#085041">Code Snippets plugin</text>

  <line x1="320" y1="68" x2="356" y2="68" stroke="#5F5E5A" stroke-width="1.25" marker-end="url(#arrow)"/>

  <!-- 3. Make webhook -->
  <rect x="360" y="40" width="130" height="56" rx="8" fill="#FAECE7" stroke="#993C1D" stroke-width="0.75"/>
  <text class="th" x="425" y="60" text-anchor="middle" fill="#4A1B0C">Make webhook</text>
  <text class="ts" x="425" y="78" text-anchor="middle" fill="#712B13">JSON payload</text>

  <line x1="490" y1="68" x2="526" y2="68" stroke="#5F5E5A" stroke-width="1.25" marker-end="url(#arrow)"/>

  <!-- 4. Google Calendar -->
  <rect x="530" y="40" width="130" height="56" rx="8" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.75"/>
  <text class="th" x="595" y="60" text-anchor="middle" fill="#26215C">Google Calendar</text>
  <text class="ts" x="595" y="78" text-anchor="middle" fill="#3C3489">Update an event</text>

  <line x1="595" y1="96" x2="595" y2="156" stroke="#5F5E5A" stroke-width="1.25" marker-end="url(#arrow)"/>

  <!-- 5. Email invite -->
  <rect x="490" y="160" width="170" height="56" rx="8" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.75"/>
  <text class="th" x="575" y="180" text-anchor="middle" fill="#26215C">Email invite sent</text>
  <text class="ts" x="575" y="198" text-anchor="middle" fill="#3C3489">Includes Google Meet link</text>

  <line x1="490" y1="188" x2="324" y2="188" stroke="#5F5E5A" stroke-width="1.25" marker-end="url(#arrow)"/>

  <!-- 6. Confirmation page -->
  <rect x="160" y="160" width="160" height="56" rx="8" fill="#F1EFE8" stroke="#5F5E5A" stroke-width="0.75"/>
  <text class="th" x="240" y="180" text-anchor="middle" fill="#2C2C2A">Confirmation page</text>
  <text class="ts" x="240" y="198" text-anchor="middle" fill="#444441">Redirect to /obrigado/</text>

  <line x1="160" y1="188" x2="89" y2="188" stroke="#5F5E5A" stroke-width="1.25" marker-end="url(#arrow)"/>
  <line x1="85" y1="184" x2="85" y2="100" stroke="#5F5E5A" stroke-width="1.25" marker-end="url(#arrow)"/>

  <!-- Alternative entry point -->
  <text class="ts" x="20" y="240" text-anchor="start" fill="#444441">Alternative entry: one-click confirmation link from email marketing</text>

  <rect x="20" y="250" width="220" height="44" rx="8" fill="#FAEEDA" stroke="#854F0B" stroke-width="0.75"/>
  <text class="th" x="130" y="266" text-anchor="middle" fill="#412402">Tracked email link</text>
  <text class="ts" x="130" y="282" text-anchor="middle" fill="#633806">?nome=...&amp;email=...&amp;empresa=...</text>

  <path d="M150 250 L150 110" fill="none" stroke="#BA7517" stroke-width="1.25" stroke-dasharray="4 3" marker-end="url(#arrow-amber)"/>
</svg>
